# === News API (optional — without this, platform uses RSS + sample data) ===
# Get free key: https://newsapi.org/register
NEWSAPI_KEY=your_key_here

# === Alpha Vantage (optional — fallback market data source) ===
# Get free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_key_here

# === Volcano Engine / Doubao LLM (optional — 4th sentiment method + AI Chat) ===
# Get from: https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint
VOLCANO_API_KEY=your_key_here
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_MODEL_ID=your_endpoint_id
